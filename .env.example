# Optional: full URL to hero background video (host on R2, Bunny, Cloudflare, etc.)
# to avoid large MP4 egress from Vercel. Must be rebuilt after changing env on Vercel.
# VITE_HERO_VIDEO_URL=https://pub-xxxxx.r2.dev/wedding/hero.mp4

# Hero uses YouTube Short dTNETpTAXDM by default (portrait cover). Optional overrides:
# VITE_HERO_YOUTUBE_ID=anotherVideoId
# VITE_HERO_YOUTUBE_DISABLED=1   # use self-hosted MP4 instead
# VITE_HERO_YOUTUBE_SHORTS=true  # 9:16 sizing for other Short IDs
